rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ebsonsilva7@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidOrder(data) {
      return data.keys().hasAll(['PEDIDO', 'CLIENTE']) &&
             (data.PEDIDO is string || data.PEDIDO is number) &&
             (data.CLIENTE is string || data.CLIENTE is number);
    }

    function isValidStats(data) {
      return data.keys().hasAll(['totalRecords', 'lastUpdated']) &&
             data.totalRecords is number &&
             data.lastUpdated is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['role', 'updatedAt']) &&
             data.role in ['admin', 'vendedor'] &&
             data.updatedAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
    }

    // Orders collection
    match /orders/{orderId} {
      allow get, list: if isAuthenticated();
      allow write: if isAdmin() && isValidOrder(request.resource.data);
    }

    // Stats document
    match /stats/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidStats(request.resource.data);
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
